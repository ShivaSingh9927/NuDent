<?xml version="1.0" encoding="utf-8"?>
<LibraryEntry xmlns="http://exocad.com/model/attachment">
	<Supplier>Invent Dental</Supplier>
	<DisplayInformation>Invent Dental - Twister Ball (Half arch)</DisplayInformation>
	<AttachmentPreviewFileName>preview.png</AttachmentPreviewFileName>
	<SupplierLogoFileName>logo.png</SupplierLogoFileName>
	<AttachmentDescription>
	
Invent Dental Twister articulator adapter for direct attachment to 3D printed model. 
 
- Free positioning along model height in X/Y, rotatable along Z.

</AttachmentDescription>
	<Placement Move="XY" Rotate="Z">
		<Translation Axis="XY" Ref="_clickpoint" DirRef="_clickpoint">
			<Const>0.0</Const>
		</Translation>
	</Placement>
	<Component IfJaw="Any" Method="AdditiveOmittingCavities" Id="anyballhu">
		<MeshFile FileName="TwisterHalf.sdfa" Retriangulate="false">
			<Translation Axis="Z">
				<Const>3.762</Const>
			</Translation>
		</MeshFile>
		<mat:Material xmlns:mat="http://exocad.com/config/color">
			<mat:Color>#C0C0C0</mat:Color>
		</mat:Material>
		<Alignment Jaw="Upper" RelativeToBottom="true"/>
	</Component>
	<Component IfJaw="Any" Method="AdditiveOmittingCavities" Id="anyballhl">
		<MeshFile FileName="TwisterHalf.sdfa" Retriangulate="false">
			<Translation Axis="Z">
				<Const>3.762</Const>
			</Translation>
		</MeshFile>
		<mat:Material xmlns:mat="http://exocad.com/config/color">
			<mat:Color>#C0C0C0</mat:Color>
		</mat:Material>
		<Alignment Jaw="Lower" RelativeToBottom="true"/>
	</Component>
	<IntersectionTestOverride Result="Test">
		<ComponentRef>anyballhl</ComponentRef>
		<BaseRef>Lower</BaseRef>
	</IntersectionTestOverride>
	<IntersectionTestOverride Result="Test">
		<ComponentRef>anyballhu</ComponentRef>
		<BaseRef>Upper</BaseRef>
	</IntersectionTestOverride>
	<GroupAll>true</GroupAll>
</LibraryEntry>