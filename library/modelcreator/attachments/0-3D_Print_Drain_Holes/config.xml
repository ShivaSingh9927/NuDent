<?xml version="1.0" encoding="utf-8"?>
<LibraryEntry xmlns="http://exocad.com/model/attachment">
	<Supplier>exocad GmbH</Supplier>
	<DisplayInformation>3D Print - Drain holes</DisplayInformation>
	<AttachmentPreviewFileName>preview.png</AttachmentPreviewFileName>
	<SupplierLogoFileName>logo.png</SupplierLogoFileName>
	<AttachmentDescription>
	
Tube geometry for substraction from upper or lower jaw model. Can be used to drain trapped resin and/or avoid a vacuum effect on 3d printed models. 

- Scalable in X/Y/Z direction. 
- Free positioning along model height in X/Y, rotatable along Z.

</AttachmentDescription>	
	<Placement Move="XY" Rotate="Z">
		<Translation Axis="XY" Ref="_clickpoint"/>
		<Constraint Type="NoTranslationZ"/>
		<Constraint Type="OnPerimeter"/>
	</Placement>
	<ControlPoint Id="center" Type="ProjectPerimeter">
		<Alignment RelativeToBottom="true"/>
		<Location/>
	</ControlPoint>
	<Parameter Scope="All" Default="2" Min="0.5" Max="4" Unit="mm" Decimals="1">Diameter</Parameter>
	<Parameter Scope="All" Default="0" Min="0" Max="5" Unit="mm" Decimals="1">Position</Parameter>
	<Parameter Scope="All" Default="4" Min="1" Max="10" Unit="mm" Decimals="1">Outer Length</Parameter>
	<Parameter Scope="All" Default="6" Min="1" Max="10" Unit="mm" Decimals="1">Inner Length</Parameter>
	<Component IfJaw="Any" Method="Subtractive" Id="any_hole">
		<MeshFile FileName="circle_cutout.eoff" Retriangulate="false">
			<Select Label="CUSP_1" >
				<Scaling Axis="YZ">
					<ParameterRef>Diameter</ParameterRef>
				</Scaling>
			</Select>
			<Select Label="CUSP_2" >
				<Scaling Axis="X">
					<ParameterRef>Outer Length</ParameterRef>
				</Scaling>
			</Select>
			<Select Label="CUSP_3" >
				<Scaling Axis="X">
					<ParameterRef>Inner Length</ParameterRef>
				</Scaling>
			</Select>
			<Select>
				<Translation Axis="Z">
					<ParameterRef>Position</ParameterRef>
				</Translation>
			</Select>
			<Rotation Axis="Z">
				<Const>90</Const>
			</Rotation>
		</MeshFile>
		<mat:Material xmlns:mat="http://exocad.com/config/color">
			<mat:Color>#4B4374</mat:Color>
			<mat:Opacity>0.5</mat:Opacity>
		</mat:Material>
		<Alignment Jaw="Any" RelativeToBottom="true"  AutoFlip="true"/>
		<Orientation Axis="Y" AroundAxis="Z" Ref="center" />
	</Component>
	<IntersectionTestOverride Result="Always">
		<ComponentRef>any_hole</ComponentRef>
		<BaseRef>Upper</BaseRef>
		<BaseRef>Lower</BaseRef>
	</IntersectionTestOverride>
</LibraryEntry>