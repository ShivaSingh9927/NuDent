		<_01>0</_01>
		<_02>0</_02>
		<_03>0</_03>
		<_10>0</_10>
		<_11>-0.25881904510252074</_11>
		<_12>0.96592582628906831</_12>
		<_13>0</_13>
		<_20>0</_20>
		<_21>0.96592582628906831</_21>
		<_22>0.25881904510252074</_22>
		<_23>0</_23>
		<_30>30</_30>
		<_31>-80</_31>
		<_32>60</_32>
		<_33>1</_33>
	</MovementregisterToArticulatorTransformation>
	<ArticulationPlaneVisualization>
		<TextureFileName>exocad_Texture_Plane.png</TextureFileName>
		<Material>
			<!--optional; same as ColorDefinition in defaultcolors.xml; except for opacity ignored if TextureFileName is defined -->
