  <DoubleParameter Name="ambient" Value="0.25" />
  <DoubleParameter Name="ambient_occlusion" Value="0.17" />
  <DoubleParameter Name="specular_exponent" Value="0.75" />
  <DoubleParameter Name="specular" Value="0.02" />
</RenderEffectSettings>